# Open WebUI Bridge local environment example.
# Copy to .env for local scripts. The Android app itself stores these values
# in app-private preferences after you enter them in the UI.

# Base URL for your Open WebUI server. Do not include /api or /api/v1.
# For Android emulator talking to host machine, this is often:
# OWUI_BASE_URL=http://10.0.2.2:3000
OWUI_BASE_URL=https://openwebui.example.local

# API key from Open WebUI Settings > Account. If present during a local
# Android build, this is embedded as a development default in BuildConfig.
# Prefer entering it in the app UI for shared or production builds.
OWUI_API_KEY=

# Optional default model id to use while testing examples or scripts.
OWUI_MODEL=

# GitHub token with read:packages for Meta Wearables DAT SDK dependencies.
GITHUB_TOKEN=

# Optional Android target when more than one device/emulator is connected.
ANDROID_SERIAL=
